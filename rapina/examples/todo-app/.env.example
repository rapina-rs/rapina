# The URL that the server will listen on
HOST=127.0.0.1

# The port that the server will listen on
PORT=3000

# The maximum number of todos the app will be able to store
MAX_TODOS=5

# Dev (SQLite, no setup needed)
DATABASE_URL=sqlite://urls.db?mode=rwc

# Prod (Postgres via docker-compose)
# DATABASE_URL=postgres://todo:todo@localhost:5432/todo
